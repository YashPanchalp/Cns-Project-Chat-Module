# Environment Configuration
# Copy this file to .env and update with your values

# ===== SERVER CONFIGURATION =====

# Port to run the server on
PORT=3000

# Node environment
NODE_ENV=development

# ===== DATABASE CONFIGURATION =====

# MongoDB local connection
MONGODB_URI=mongodb://localhost:27017/secure-chat

# MongoDB Atlas (Cloud) - Uncomment and update with your credentials
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/secure-chat?retryWrites=true&w=majority

# ===== ENCRYPTION CONFIGURATION (Optional) =====

# Key rotation interval (in hours)
KEY_ROTATION_INTERVAL=24

# Enable ECDH key exchange (recommended for production)
USE_ECDH_KEY_EXCHANGE=false

# ===== LOGGING =====

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ===== SOCKET.IO CONFIGURATION =====

# Enable CORS for specified origins
SOCKET_CORS_ORIGIN=*

# ===== SECURITY =====

# Enable HTTPS (requires cert.pem and key.pem files)
USE_HTTPS=false

# Session secret
SESSION_SECRET=your-secure-secret-key-change-in-production
